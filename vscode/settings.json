{
    "git.openRepositoryInParentFolders": "always",
    "mise.binPath": "/Users/mizuki-y/.local/bin/mise",
    "editor.minimap.enabled": false,
    "workbench.tree.indent": 16,
    "terminal.integrated.defaultProfile.osx": "zsh",
    //"workbench.activityBar.location": "hidden",
    "workbench.editor.showTabs": "none",
    "projectManager.git.baseFolders": [
        "~/Projects",
        "~/.dot.d"
    ],
    "workbench.startupEditor": "none",
    "debug.javascript.defaultRuntimeExecutable": {
        "pwa-node": "/Users/mizuki-y/.local/share/mise/shims/node"
    },
    "multiCommand.commands": [
        {
            "command": "multiCommand.toggleAndFocusSecondarySidebar",
            "sequence": [
                "workbench.action.toggleAuxiliaryBar",
                "workbench.action.focusAuxiliaryBar"
            ]
        }
    ],
    "scm.compactFolders": false,
    "explorer.compactFolders": false,
    "notebook.compactView": false,
    "workbench.iconTheme": "material-icon-theme",
    "explorer.confirmDelete": false,
    "explorer.autoReveal": true,
    "workbench.editor.revealIfOpen": true,
    "git.blame.editorDecoration.enabled": true,
    "files.insertFinalNewline": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "security.workspace.trust.untrustedFiles": "open",
    "github.copilot.nextEditSuggestions.enabled": true,
    "redhat.telemetry.enabled": false,
    "editor.fontFamily": "'Meslo LG M for Powerline', Monaco, 'Courier New', monospace",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.unicodeHighlight.invisibleCharacters": false,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "rubyLsp.formatter": "rubocop",
    "[ruby]": {
        "editor.defaultFormatter": "Shopify.ruby-lsp",
        "editor.formatOnSave": true
    },
    "[shellscript]": {
        "editor.defaultFormatter": "foxundermoon.shell-format"
    },
    "files.associations": {
        "*.sh": "shellscript"
    },
    "chat.tips.enabled": false,
    "github.copilot.chat.localeOverride": "ja",
    "debug.onTaskErrors": "debugAnyway",
    "chat.viewSessions.orientation": "stacked",
    "fzf-picker.customTasks": [
        {
            "name": "zoxide",
            "command": "code $(zoxide query --interactive)"
        }
    ],
    "fzf-picker.general.openCommand": "code -g",
    "yazi-vscode.useWorkspaceFolder": true,
    "shellformat.path": "/opt/homebrew/bin/shfmt",
    "yaml.disableSchemaDetection": [
        "**/.github/workflows/*.yml",
        "**/.github/workflows/*.yaml",
        "**/.gitea/workflows/*.yml",
        "**/.gitea/workflows/*.yaml",
        "**/.forgejo/workflows/*.yml",
        "**/.forgejo/workflows/*.yaml"
    ]
}
