# Config syntax crash course
# ==========================
# # The config file consists of simple key-value pairs,
# # separated by equals signs.

font-family = JetBrains Mono NL

# window-padding-x = 2
#
# # Spacing around the equals sign does not matter.
# # All of these are identical:
# key=value
# key= value
# key =value
# key = value
#
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc
#
# # Empty values are used to reset config keys to default.
# key =
#
# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms
background-blur-radius = 20
background-opacity = 0.9

quick-terminal-position = "left"
quick-terminal-screen = "main"
quick-terminal-size = 30%
quick-terminal-animation-duration = 0.3
macos-option-as-alt = left

keybind = clear
keybind = global:cmd+shift+alt+ctrl+t=toggle_quick_terminal

keybind = cmd+t=toggle_command_palette
keybind = cmd+x>r=reload_config
keybind = cmd+`=write_screen_file:open

# search
keybind = cmd+s=start_search
keybind = cmd+shift+s=end_search

# split設定
keybind = cmd+x>k=close_surface
keybind = cmd+x>2=new_split:right
keybind = cmd+x>3=new_split:down
keybind = cmd+x>o=goto_split:next
keybind = cmd+x>shift+o=goto_split:previous
#keybind = cmd+x>cmd+o=goto_split:next
#keybind = cmd+o=goto_split:next
#keybind = cmd+h=goto_split:left
#keybind = cmd+j=goto_split:bottom
#keybind = cmd+k=goto_split:top
#keybind = cmd+l=goto_split:right
keybind = cmd+shift+up=resize_split:up,10
keybind = cmd+shift+down=resize_split:down,10
keybind = cmd+shift+left=resize_split:left,10
keybind = cmd+shift+right=resize_split:right,10


# tab設定
keybind = cmd+x>cmd+n=new_tab
keybind = cmd+x>cmd+k=close_tab
keybind = cmd+n=next_tab
keybind = cmd+p=previous_tab
keybind = cmd+1=goto_tab:1
keybind = cmd+2=goto_tab:2
keybind = cmd+3=goto_tab:3
keybind = cmd+4=goto_tab:4
keybind = cmd+5=goto_tab:5
keybind = cmd+shift+n=move_tab:1
keybind = cmd+shift+p=move_tab:-1

keybind = alt+p=jump_to_prompt:-1
keybind = alt+n=jump_to_prompt:1

# codex などで paste するため
keybind = cmd+v=paste_from_clipboard
keybind = ctrl+y=paste_from_clipboard

